<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_employee_resignation" model="ir.ui.view">
        <field name="name">employee.resignation.view</field>
        <field name="model">hr.resignation</field>
        <field name="inherit_id" ref="hr_resignation.hr_resignation_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button name="view_survey_details" type="object" class="oe_stat_button"
                            icon="fa-check-square-o">
                        <field string="Participants" name="answer_done_count" widget="statinfo"/>
                    </button>
                </div>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_open_survey_invite" string="Share Survey"
                        type="object"
                        class="btn-primary"/>
            </xpath>
        </field>
    </record>
</odoo>