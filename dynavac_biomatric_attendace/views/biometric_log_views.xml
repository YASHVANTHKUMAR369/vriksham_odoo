<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_biometric_log_list" model="ir.ui.view">
        <field name="name">biometric.log.view.list</field>
        <field name="model">biometric.log</field>
        <field name="arch" type="xml">
            <list string="Biometric Logs" multi_edit="1" create="false" edit="1" delete="1" decoration-warning="state == 'skipped'" decoration-success="state == 'processed'">
                <field name="employee_id"/>
                <field name="employee_code"/>
                <field name="log_date"/>
                <field name="serial_number"/>
                <field name="device_name"/>
                <field name="state"/>
<!--                <field name="processed" readonly="0"/>-->

            </list>
        </field>
    </record>

    <record id="action_biometric_log" model="ir.actions.act_window">
        <field name="name">Biometric Logs</field>
        <field name="res_model">biometric.log</field>
        <field name="view_mode">list,search</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Biometric Logs found.
            </p>
        </field>
    </record>

    <record id="biometric_log_view_search" model="ir.ui.view">
        <field name="name">biometric.log.search</field>
        <field name="model">biometric.log</field>
        <field name="arch" type="xml">
            <search string="Biometric Log">
                <field name="employee_id"/>
                <field name="employee_code"/>
                <field name="log_date"/>
                <field name="serial_number"/>
                <field name="device_name"/>
                <field name="state"/>
                <separator/>
                <filter string="Not Employee" name="not_employee" domain="[('employee_id', '=', False)]" help="Show empty employee id record"/>
                <filter string="Employee" name="employee" domain="[('employee_id', '!=', False)]" help="Show employee id record"/>
                <separator/>
                <filter string="Not Processed" name="not_processed" domain="[('state', '=', False)]" help="Show not processed record"/>
                <filter string="Processed" name="processed" domain="[('state', '=', 'processed')]" help="Show processed record"/>
                <filter string="Skipped" name="skipped" domain="[('state', '=', 'skipped')]" help="Show skipped record"/>
                <separator/>
                <filter string="Date" name="check_in_filter" date="log_date"/>
                <filter string="Today" name="filter_log_date" domain="[('log_date', '&gt;=', 'today')]"/>
                <group>
                    <filter string="Employee Code" name="group_employee_code"
                            context="{'group_by': 'employee_code'}"/>
                    <filter string="Employee" name="group_employee_id" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_by_date" string="Log date Date" context="{'group_by': 'log_date:day'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>