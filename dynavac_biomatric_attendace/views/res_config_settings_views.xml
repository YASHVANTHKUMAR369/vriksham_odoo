<?xml version="1.0" encoding="utf-8"?>
<odoo>
    Adding fields in res.config.settings
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.employee.biometric.attendace</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_attendance.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='hr_attendance']" position="inside">
                <block title="Biometric Attendance Settings">
                    <setting id="from_date" company_dependent="1">
                        <field name="from_date" readonly="0"/>
                    </setting>
                    <setting id="biometric_api_url" company_dependent="1"
                             help="API URL.">
                        <field name="biometric_api_url" readonly="0"/>
                    </setting>
                    <setting id="to_date" company_dependent="1">
                        <field name="to_date" readonly="0"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
