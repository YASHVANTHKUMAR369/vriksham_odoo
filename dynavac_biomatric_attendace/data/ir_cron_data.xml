<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ir_cron_biometric_attendance" model="ir.cron">
            <field name="name">Attendance: biometric</field>
            <field name="model_id" ref="model_biometric_log"/>
            <field name="state">code</field>
            <field name="code">model.biometric_attendance()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>
        <record id="ir_cron_attendance_create_day_by_day" model="ir.cron">
            <field name="name">Attendance: create day by day</field>
            <field name="model_id" ref="model_biometric_log"/>
            <field name="state">code</field>
            <field name="code">model.create_attendance_start_end()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <record id="act_ir_cron_process_biometric_attendance" model="ir.actions.server">
            <field name="name">Create Attendance</field>
            <field name="model_id" ref="dynavac_biomatric_attendace.model_biometric_log"/>
            <field name="state">code</field>
            <field name="code">
                records.create_attendance_start_end()
            </field>
            <field name="binding_model_id" ref="dynavac_biomatric_attendace.model_biometric_log"/>
            <field name="binding_view_types">list</field>
        </record>

        <record id="act_ir_cron_process_biometric_skip" model="ir.actions.server">
            <field name="name">Skip</field>
            <field name="model_id" ref="dynavac_biomatric_attendace.model_biometric_log"/>
            <field name="state">code</field>
            <field name="code">
                records.skipped_data()
            </field>
            <field name="binding_model_id" ref="dynavac_biomatric_attendace.model_biometric_log"/>
            <field name="binding_view_types">list</field>
        </record>

    </data>
</odoo>
