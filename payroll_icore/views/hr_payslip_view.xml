<odoo>
    <record id="view_payslip_form_inherit" model="ir.ui.view">
        <field name="name">hr.payslip.form.inherit</field>
        <field name="model">hr.payslip</field>
	<field name="inherit_id" ref="hr_payroll_community.hr_payslip_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='worked_days_line_ids']" position="after">
                <field name="worked_days_line_ids" widget="one2many_list"/>
            </xpath>
        </field>
    </record>
</odoo>
