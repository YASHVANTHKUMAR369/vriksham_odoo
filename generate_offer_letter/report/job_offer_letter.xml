<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_offer_letter" model="ir.actions.report">
        <field name="name">Offer Letter</field>
        <field name="model">hr.job.offer</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">generate_offer_letter.offer_letter</field>
        <field name="report_file">generate_offer_letter.offer_letter</field>
        <field name="print_report_name">'Offer Letter - %s' % (object.candidate_id.partner_name)</field>
        <field name="binding_model_id" ref="model_hr_job_offer"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_offer_letter">
        <t t-call="web.external_layout">
            <div class="page">

                <!-- Title -->
                <h2 style="text-align:center;">
                    <b>OFFER LETTER</b>
                </h2>

                <br/>

                <!-- Reference -->
                <div class="row">
                    <div class="col-6">
                        <strong>Ref.No:</strong>
                        <strong t-esc="doc.name"/>
                    </div>
                    <div class="col-6" style="text-align:right;">
                        <strong t-esc="doc.joining_date.strftime('%d-%b-%Y') if doc.joining_date else '-'"/>
                    </div>
                </div>
                <!-- Address -->
                <p class="mt-2">
                    <strong t-esc="doc.candidate_id.partner_name"/>
                    <t t-esc="doc.candidate_address"/>
                </p>

                <br/>

                <!-- Content -->
                <p><strong t-esc="doc.candidate_id.partner_name"/>,
                </p>

                <p>
                    We refer to your candidature and to our discussions. We are pleased to offer you an appointment with
                    our organization. Welcome onboard as a VSTian!
                </p>

                <p>
                    Your designation will be<srong class="ms-1" t-esc="doc.job_title.display_name"/>. Your base location
                    will be
                    <strong class="ms-1">Tiruvannamalai</strong>
                    unless notified
                    otherwise.
                </p>

                <p>
                    Your CTC will be
                    <strong class="ms-1" t-esc="doc.gross_salary"/>
                    <strong class="ms-1">/- Per Annum</strong>, the detailed Compensation package offered
                    to you are given in
                    Annexure A.
                </p>

                <p>
                    The documentation necessary at the time of your joining is listed in Annexure B.
                </p>

                <p>
                    Your joining date is<strong class="ms-1"
                                                t-esc="doc.joining_date.strftime('%d-%b-%Y') if doc.joining_date else '-'"/>
                    .
                    Please convey your acceptance of this offer within 3 days of
                    receiving this offer.
                </p>

                <p>
                    You will be on 30 days of notice as per the company policy.
                </p>

                <p>
                    We welcome you to
                    <p t-esc="doc.company_id.display_name"/>
                    and looking forward to a long and mutually rewarding
                    association with you.
                </p>

                <br/>
                <br/>

                <p>For<strong class="ms-1" t-esc="doc.company_id.display_name"/>,
                </p>

                <br/>
                <br/>

                <p>
                    <b>
                        <strong>Vinodhini D</strong>
                    </b>
                    <br/>
                    <strong>HR HEAD</strong>
                </p>

                <!-- Annexure A -->
                <div style="page-break-before: always;"></div>

                <h3 class="text-center">
                    <b>Annexure - A</b>
                </h3>
                <h4>Compensation Structure</h4>
                <t t-esc="doc.salary_calculation_report"/>

                <!-- Annexure B -->
                <h3 class="text-center">
                    <b>Annexure - B</b>
                </h3>

                <p>
                    At the time of joining, you are requested to bring the following documents in original, along with
                    one copy each.
                </p>

                <ul>
                    <li>Certificates supporting your educational qualifications along with mark sheets</li>
                </ul>
                <ol style="margin-left: 50px;">
                    <li>Std X Certificate and mark sheet</li>
                    <li>Std XII Certificate and mark sheet</li>
                    <li>Degree Certificate and Semester-wise / Year-wise mark sheets</li>
                    <li>Master’s Degree Certificate and Semester-wise / Year-wise mark sheets</li>
                    <li>Diploma / PG Diploma Certificate and Transcripts</li>
                    <li>Any other Certificates with supporting documents, if any</li>
                </ol>

                <ul>
                    <li>Your latest salary slip / Salary Certificate</li>
                    <li>Your relieving letter / Service Certificate from the last three employers</li>
                    <li>Acknowledged copy of our offer of appointment</li>
                    <li>4 passport sized colour photographs with white background</li>
                    <li>Valid pages of the Passport</li>
                    <li>Valid government ID proof for your current / permanent address</li>
                    <li>PAN Card</li>
                </ul>

                <p>
                    Please bring all the Certificates supporting your educational qualifications along with mark sheets
                    in original for verification only.
                </p>

            </div>
        </t>
    </template>

    <template id="offer_letter">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="generate_offer_letter.report_offer_letter"/>
            </t>
        </t>
    </template>

</odoo>
