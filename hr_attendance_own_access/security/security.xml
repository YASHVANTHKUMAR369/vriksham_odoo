<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="group_hr_attendance_own" model="res.groups">
            <field name="name">Own Attendance Only</field>
            <field name="sequence">12</field>
            <field name="privilege_id" ref="hr_attendance.res_groups_privilege_attendances"/>
            <field name="implied_ids" eval="[(4, ref('hr_attendance.group_hr_attendance_own_reader'))]"/>
            <field name="comment">The user can create and edit only their own attendances.</field>
        </record>

        <record id="hr_attendance.group_hr_attendance_user" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('hr_attendance_own_access.group_hr_attendance_own'))]"/>
        </record>

        <record id="hr_attendance_rule_attendance_own_create_write" model="ir.rule">
            <field name="name">Attendance Own: Create and edit own attendances</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('hr_attendance_own_access.group_hr_attendance_own'))]"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_unlink" eval="0"/>
            <field name="perm_read" eval="1"/>
        </record>
    </data>
</odoo>
