<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payroll_report_view" model="ir.ui.view">
        <field name="name">payroll.report.form.view</field>
        <field name="model">payroll.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Payroll Report">
                <sheet>
                    <group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_xlsx" string="Print"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="payroll_report_action" model="ir.actions.act_window">
        <field name="name">Payroll Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">payroll.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="payroll_report_view"/>
        <field name="target">new</field>
    </record>
    <!-- Menu -->
    <menuitem id="payroll_report_menu"
              name="Report"
              parent="hr_payroll_community.menu_hr_payroll_community_root"/>
    <menuitem id="payroll_report_menu_action"
              name="Payroll Report"
              parent="payroll_report_menu"
              action="payroll_report_action"/>
</odoo>