<odoo>
    <record id="hr_expense_approval_history_form" model="ir.ui.view">
        <field name="name">hr.expense.approval.history.form</field>
        <field name="model">hr.expense.approval.history</field>
        <field name="arch" type="xml">
            <form string="Approval History">
                <sheet>
                    <group>

                        <field name="expense_id" readonly="1"/>
                        <field name="user_id" readonly="1"/>
                        <field name="sequence" readonly="1"/>

                        <!-- Editable -->
                        <field name="date" readonly="1"/>
                        <field name="state"/>

                        <field name="note"/>

                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- TREE VIEW -->
    <record id="view_hr_expense_approval_step_tree" model="ir.ui.view">
        <field name="name">hr.expense.approval.step.tree</field>
        <field name="model">hr.expense.approval.step</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="approve_by"/>
                <field name="user_id"/>
                <field name="min_amount"/>
                <field name="max_amount"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <!-- Employee Form Inherit -->
    <record id="hr_employee_form_expense_approval" model="ir.ui.view">
        <field name="name">hr.employee.form.expense.approval</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <page string="Expense Approvals">

                    <field name="expense_approval_step_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="approve_by"/>
                            <field name="user_id"/>
<!--                            <field name="min_amount"/>-->
<!--                            <field name="max_amount"/>-->
                        </list>
                    </field>

                </page>

            </xpath>

        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_hr_expense_approval_step_form" model="ir.ui.view">
        <field name="name">hr.expense.approval.step.form</field>
        <field name="model">hr.expense.approval.step</field>
        <field name="arch" type="xml">
            <form string="Expense Approval Rule">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="company_id"/>
                        </group>

                        <group>
                            <field name="approve_by"/>
                            <field name="user_id" />
<!--                            <field name="user_id"-->
<!--                                   attrs="{'invisible':[('approve_by','!=','specific_user')],-->
<!--                                           'required':[('approve_by','=','specific_user')]}"/>-->
                        </group>
                    </group>

                    <group string="Amount Condition">
                        <field name="min_amount"/>
                        <field name="max_amount"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_hr_expense_approval_step" model="ir.actions.act_window">
        <field name="name">Expense Approval Rules</field>
        <field name="res_model">hr.expense.approval.step</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>
                Configure multi-level approval flow for employee expenses.
            </p>
        </field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_hr_expense_approval_root"
              name="Expense Approvals"
              parent="hr_expense.menu_hr_expense_configuration"
              sequence="60"/>

    <menuitem id="menu_hr_expense_approval_rules"
              name="Approval Rules"
              parent="menu_hr_expense_approval_root"
              action="action_hr_expense_approval_step"/>

</odoo>
