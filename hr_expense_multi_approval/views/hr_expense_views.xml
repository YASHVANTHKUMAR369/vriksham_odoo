<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="hr_expense_form_multi_approval" model="ir.ui.view">
        <field name="name">hr.expense.form.multi.approval</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">

                <button name="action_multi_approve"
                        string="Approve"
                        type="object"
                        class="btn-primary" invisible="state != 'in_approval'"/>

                <button name="action_multi_reject"
                        string="Reject"
                        type="object"
                        class="btn-danger" invisible="state != 'in_approval'"/>

            </xpath>


            <!-- Approval Info -->
            <xpath expr="//field[@name='manager_id']" position="after">
                <group string="Approval Info">
                    <field name="current_approval_id" readonly="1"/>
                </group>
            </xpath>

              <!-- Insert new tab inside notebook -->
             <!-- Insert notebook AFTER notes -->
            <xpath expr="//sheet" position="inside">

                <notebook>

                    <page string="Approval History">

                        <field name="approval_history_ids" nolabel="1" readonly="1">

                            <list create="0" delete="0" edit="0"
                                  decoration-success="state == 'approved'"
                                  decoration-danger="state == 'rejected'"
                                  decoration-warning="state == 'waiting'">

                                <field name="sequence" string="Level"/>
                                <field name="user_id" string="Approver"/>
                                <field name="state"/>
                                <field name="date"/>
                                <field name="note"/>

                            </list>

                        </field>

                    </page>

                </notebook>

            </xpath>
        </field>
    </record>

</odoo>
