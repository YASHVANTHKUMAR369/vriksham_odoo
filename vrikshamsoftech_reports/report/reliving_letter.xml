<odoo>
    <data>

        <record id="vriksham_action_record_reliving_letter" model="ir.actions.report">
            <field name="name">Relieving letter</field>
            <field name="model">hr.employee</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">vrikshamsoftech_reports.vriksham_reliving_letter_template</field>
            <field name="report_file">vrikshamsoftech_reports.vriksham_reliving_letter_template</field>
            <field name="print_report_name">'%s - Reliving letter' % (object.name).replace('/', '')</field>
            <field name="binding_model_id" ref="hr.model_hr_employee"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="vrikshamsoftech_reports.vriksham_paper_format_experience_letter"/>
        </record>


        <template id="vriksham_reliving_letter_template">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <t t-foreach="docs" t-as="o">
                        <t t-call="vrikshamsoftech_reports.vriksham_header_formate_experience_letter"/>

                        <div class="mt-3">
                            <t t-if="o.departure_date == False and o.active == True">
                                <center style="color:red">
                                    <strong style="font-size:15px;">This employee currently Working on</strong>
                                    -
                                    <strong style="font-size:13px;" t-esc="res_company.name"/>
                                </center>
                            </t>
                        </div>
                        <t t-set="today" t-value="o.create_date.today()"/>

                        <div class="mt-3 text-end" style="text-align:right">
<!--                            <t t-if="o.departure_date">-->
<!--                                <span t-esc="o.departure_date.strftime('%d/%m/%Y')"/>-->
<!--                            </t>-->
<!--                            <t t-else="">-->
                                <span t-esc="today.strftime('%d/%m/%Y')"/>
<!--                            </t>-->
                        </div>
                        <div class="mt-3">
                            <strong t-field="o.name"/>
                            <br/>
                            Employee No :
                            <strong t-field="o.registration_number"/>
                            <br/>
                            RE : Reliving Letter
                        </div>
                        <div class="mt-3">
                            Dear
                            <strong t-field="o.name"/>,
                        </div>
                        <div class="mt-3">
                            <span>
                                This is with reference to your resignation letter dated
                                <span t-esc="o.x_resignation_date.strftime('%B %d, %Y') if o.x_resignation_date else 'DD-MM-YY'"/>. You are
                                relieved of your duties with Vriksham Soft Tech with effect from the close of business
                                hours of
                                <t t-if="o.departure_date">
                                    <span t-esc="o.departure_date.strftime('%B %d %Y')"/>
                                </t>
                                <t t-else="">
                                    <strong>DD-MM-YY</strong>
                                </t>
                                . This letter confirms the following details of your employment
                                with us:

                            </span>
                        </div>
                        <table class="table table-sm p-2 mt-4">
                            <tbody>
                                <tr>
                                    <th scope="row">Date of Joining</th>
                                    <td>
                                        <t t-if="o.x_date_of_joining">
                                            <span t-esc="o.x_date_of_joining.strftime('%B %d, %Y')"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">Profile Job</th>
                                    <td>
                                        <t t-if="o.job_id">
                                            <span t-esc="o.job_id.name"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">Reason for Exit</th>
                                    <td>
                                        <span>Resignation</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="mt-3">
                            <span>You agree that no amounts are due and owing to you by
                                <strong t-esc="res_company.name if res_company.name else '[ res_company ]'"/>.
                            </span>
                        </div>
                        <div class="mt-3">
                            <span>You confirm that you have returned to Vriksham Soft Tech all materials in your
                                possession, custody, or control and provided to you or created in the course of your
                                employment with Vriksham Soft Tech (including keys, ID card, access card, and laptop).
                            </span>
                        </div>
                        <div class="mt-3">
                            <span>We wish you success in your future endeavors.</span>
                        </div>
                        <div class="text-start" style="margin-top:220px">
                            <span>
                                For
                                <strong t-out="res_company.name if res_company.name else ''"/>
                            </span>
                        </div>
                        <div class="row">
                            <div class="col-12 text-start">
                                <t t-if="o.env.user.sign_signature">
                                    <img t-att-src="image_data_uri(o.env.user.sign_signature)"
                                         style="max-height: 50pt; max-width: 100%;" alt="Employee Image"/>
                                </t>
                                <t t-else="">
                                    <div class="col-12" style="min-height: 10rem"/>
                                </t>

                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <strong>
                                    Jeevitha D
                                    <br/>
                                    Head - Human Resources
                                </strong>
                            </div>
                            <div class="col-6 text-end">
                            </div>
                        </div>

<!--                        <t t-call="vrikshamsoftech_reports.vriksham_footer_formate_experience_letter"/>-->
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>