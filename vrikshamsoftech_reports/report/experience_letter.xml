<odoo>
    <data>

        <record id="vriksham_paper_format_experience_letter" model="report.paperformat">
            <field name="name">Experience letter payslip paper format</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">45</field>
            <field name="margin_bottom">15</field>
            <field name="margin_left">15</field>
            <field name="margin_right">15</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">45</field>
            <field name="dpi">80</field>
        </record>

        <record id="vriksham_action_record_experience_letter" model="ir.actions.report">
            <field name="name">Experience letter</field>
            <field name="model">hr.employee</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">vrikshamsoftech_reports.vriksham_experience_letter_template</field>
            <field name="report_file">vrikshamsoftech_reports.vriksham_experience_letter_template</field>
            <field name="print_report_name">'%s - Experience letter' % (object.name).replace('/', '')</field>
            <field name="binding_model_id" ref="hr.model_hr_employee"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="vrikshamsoftech_reports.vriksham_paper_format_experience_letter"/>
        </record>

        <template id="vriksham_header_formate_experience_letter">
