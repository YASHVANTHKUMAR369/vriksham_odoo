                <br/>
                <table class="table table-sm table-borderless mt-1">
                    <tr>
                        <td>
                            <img src="/web/binary/company_logo" width="50%"
                                 class="img-responsive mt-1"/>
                        </td>
                        <td class="text-end">
                            <strong style="font-size:13px;" t-esc="res_company.name"/>
                            <span t-esc="res_company.partner_id" style="font-size:13px;"
                                  t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>

                            <span style="font-size:13px;" t-esc="res_company.phone"/>
                        </td>
                    </tr>
                </table>
                <div name="watermark" style="margin-top:300px">
                    <img src="/web/binary/company_logo" width="100%" style="opacity: 0.1;"
                         class="img-responsive"/>
                </div>
            </div>
        </template>

