        <template id="vriksham_experience_letter_template">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <t t-foreach="docs" t-as="o">
                        <t t-call="vrikshamsoftech_reports.vriksham_header_formate_experience_letter"/>

                        <div class="mt-3">
                            <t t-if="o.departure_date == False and o.active == True">
                                <center style="color:red">
                                    <strong style="font-size:15px;">This employee currently Working on</strong>
                                    -
                                    <strong style="font-size:13px;" t-esc="res_company.name"/>
                                </center>
                            </t>
                        </div>
                        <t t-set="today" t-value="o.create_date.today()"/>

                        <div class="mt-3 text-end" style="text-align:right">
                            <!--                            <t t-if="o.departure_date">-->
                            <!--                                <span t-esc="o.departure_date.strftime('%d/%m/%Y')"/>-->
                            <!--                            </t>-->
                            <!--                            <t t-else="">-->
                            <span t-esc="today.strftime('%d/%m/%Y')"/>
                            <!--                            </t>-->
                        </div>
                        <div class="mt-3">
                            <strong t-field="o.name"/>
                            <br/>
                            Employee No :
                            <strong t-field="o.registration_number"/>
                            <br/>
                            RE : Experience Letter
                        </div>
                        <div class="mt-3">
                            Dear
                            <strong t-field="o.name"/>,
                        </div>
                        <div class="mt-3">
                            <span>This is to confirm that
                                <span t-field="o.name"/>
                                was employed with Vriksham Soft Tech for the period
                                <t t-if="o.x_date_of_joining">
                                    <span t-esc="o.x_date_of_joining.strftime('%B %d, %Y')"/>
                                </t>
                                <t t-else="">
                                    <strong>DD-MM-YY</strong>
                                </t>
                                to
                                <t t-if="o.departure_date">
                                    <span t-esc="o.departure_date.strftime('%B %d, %Y')"/>
                                </t>
                                <t t-else="">
                                    <strong>DD-MM-YY</strong>
                                </t>
                                . At the time of resignation,
                                he
                                was designated as an

                                <t t-if="o.job_id">
                                    <span t-esc="o.job_id.name"/>
                                </t>
                                <t t-else="">
                                    <strong>JOB</strong>
                                </t>
                            </span>
                        </div>
                        <div class="mt-3">
                            <span>This letter is issued as proof of work experience.</span>
                        </div>
                        <div class="mt-3">
                            <span>We wish you success in your future endeavors and hope that your career path is filled
                                with success and growth. Should you need any assistance or reference in the future,
                                please do not hesitate to reach out to us.
                            </span>
                        </div>
                        <div class="mt-3">
                            <strong>Your service record is as follows :</strong>
                            <table class="table table-sm p-2 mt-4">
                                <tbody>
                                    <tr>
                                        <th scope="row">Name</th>
                                        <td>
                                            <t t-if="o.name">
                                                <span t-esc="o.name"/>
                                            </t>
                                            <t t-else="">
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th scope="row">Designation</th>
                                        <td>
                                            <t t-if="o.job_id">
                                                <span t-esc="o.job_id.name"/>
                                            </t>
                                            <t t-else="">
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th scope="row">Date of Joining</th>
                                        <td>
                                            <t t-if="o.x_date_of_joining">
                                                <span t-esc="o.x_date_of_joining.strftime('%B %d, %Y')"/>
                                            </t>
                                            <t t-else="">
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th scope="row">Date of Leaving</th>
                                        <td>
                                            <t t-if="o.departure_date">
                                                <span t-esc="o.departure_date.strftime('%B %d, %Y')"/>
                                            </t>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="mt-3">
                            <span>We would like to remind you of your ongoing obligation to maintain the confidentiality
                                of any proprietary and confidential information of the company that you accessed during
                                your employment.
                            </span>
                        </div>
                        <div class="mt-3">
                            <span>Thank you for your contributions to
                                <strong t-esc="res_company.name if res_company.name else '[ res_company ]'"/>.
                                We wish you all the best in your future endeavors!
                            </span>
                        </div>
                        <div class="text-start" style="margin-top:50px">
                            <span>
                                For
                                <strong t-out="res_company.name if res_company.name else ''"/>
                            </span>
                        </div>
                        <!-- <div class="row">
                            <div class="col-12 text-start">
                                <t t-if="o.env.user.sign_signature">
                                    <img t-att-src="image_data_uri(o.env.user.sign_signature)"
                                         style="max-height: 50pt; max-width: 100%;" alt="Employee Image"/>
                                </t>
                                <t t-else="">
                                    <div class="col-12" style="min-height: 10rem"/>
                                </t>

                            </div>
                        </div> -->
                        <div class="row">
                            <div class="col-6">
                                <strong>
                                    <!--                                    <t t-out="o.parent_id.name"/>-->
                                    Jeevitha D
                                    <br/>
                                    Head - Human Resources
                                </strong>
                            </div>
                            <div class="col-6 text-end">
                                <!--                                <br/>-->
                                <!--                                <span>Authorized-->
                                <!--                                    signatory-->
                                <!--                                </span>-->
                            </div>
                        </div>

<!--                        <t t-call="vrikshamsoftech_reports.vriksham_footer_formate_experience_letter"/>-->
                    </t>
                </t>
            </t>
        </template>

