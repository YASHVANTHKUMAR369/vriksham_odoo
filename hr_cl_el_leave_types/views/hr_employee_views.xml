<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_form_inherited" model="ir.ui.view">
        <field name="name">hr.employee.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="after">
                <page string="Leave Configuration">
                    <field name="leave_config_id" nolabel="1">
                        <list editable="bottom">
                            <field name="cl_balance"/>
                            <field name="el_balance"/>
                        </list>
                    </field>
                </page>
                <!-- <field name="cl_balance" string="Available Casual Leave"/>
                <field name="el_balance" string="Available Earned Leave"/>
                <field name="probation_end_date"/>
                <field name="notice_start_date"/> -->
            </xpath>
        </field>
    </record>
</odoo>
