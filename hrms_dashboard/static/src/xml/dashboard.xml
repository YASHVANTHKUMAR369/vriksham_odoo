<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="HrDashboardMain">
        <div class="cd-dashboard container-fluid py-3">
            <t t-if="this.state.login_employee">
                <div class="row g-3">
                    <div class="col-12 col-xl-3">
                        <t t-call="LoginEmployeeDetails"/>
                    </div>
                    <div class="col-12 col-xl-9">
                        <t t-call="EmployeeDashboard"/>
                        <t t-if="this.state.is_manager == true">
                            <t t-call="ManagerDashboard"/>
                        </t>
                    </div>
                </div>
            </t>
        </div>
    </t>

    <t t-name="LoginEmployeeDetails">
        <section class="cd-card cd-profile h-100">
            <div class="cd-profile-head text-center">
                <t t-if="this.state.login_employee['image_1920']">
                    <img class="cd-avatar"
                         alt="Employee"
                         t-att-src="'data:image/png;base64,'+this.state.login_employee['image_1920']"/>
                </t>
                <h2 class="cd-name"><t t-esc="this.state.login_employee['name']"/></h2>
                <p class="cd-role" t-if="this.state.login_employee['job_id']"><t t-esc="this.state.login_employee['job_id'][1]"/></p>
                <p class="cd-role" t-if="!this.state.login_employee['job_id']">No Job Title</p>
            </div>
            <div class="cd-profile-meta">
                <div class="cd-meta-item">
                    <span class="cd-meta-label">Joined</span>
                    <span class="cd-meta-value" t-if="this.state.login_employee['experience']"><t t-esc="this.state.login_employee['experience']"/> Ago</span>
                    <span class="cd-meta-value" t-if="!this.state.login_employee['experience']">--/--/----</span>
                </div>
                <div class="cd-meta-item">
                    <span class="cd-meta-label">Phone</span>
                    <span class="cd-meta-value"><t t-esc="this.state.login_employee['mobile_phone'] or '---'"/></span>
                </div>
                <div class="cd-meta-item">
                    <span class="cd-meta-label">Email</span>
                    <span class="cd-meta-value"><t t-esc="this.state.login_employee['work_email'] or '---'"/></span>
                </div>
                <div class="cd-meta-item">
                    <span class="cd-meta-label">Address</span>
                    <span class="cd-meta-value">
                        <t t-if="this.state.login_employee['private_street']"><t t-esc="this.state.login_employee['private_street']"/></t>
                        <t t-if="this.state.login_employee['private_street2']">, <t t-esc="this.state.login_employee['private_street2']"/></t>
                        <t t-if="this.state.login_employee['private_city']">, <t t-esc="this.state.login_employee['private_city']"/></t>
                        <t t-if="this.state.login_employee['private_state_id']">, <t t-esc="this.state.login_employee['private_state_id'][1]"/></t>
                        <t t-if="this.state.login_employee['private_zip']">, <t t-esc="this.state.login_employee['private_zip']"/></t>
                        <t t-if="this.state.login_employee['private_country_id']">, <t t-esc="this.state.login_employee['private_country_id'][1]"/></t>
                    </span>
                </div>
            </div>
        </section>
    </t>

    <t t-name="EmployeeDashboard">
        <section class="cd-block cd-kpi-block">
            <div class="row g-3">
                <div class="col-12 col-md-6 col-xl">
                    <button type="button" class="cd-kpi cd-kpi-payslip" t-on-click="hr_payslip">
                        <span class="cd-kpi-icon"><i class="fa fa-money"/></span>
                        <span class="cd-kpi-body">
                            <span class="cd-kpi-label">Payslips</span>
                            <span class="cd-kpi-value"><t t-esc="this.state.login_employee['payslip_count']"/></span>
                        </span>
                    </button>
                </div>
                <div class="col-12 col-md-6 col-xl">
                    <button type="button" class="cd-kpi cd-kpi-timesheet" t-on-click="hr_timesheets">
                        <span class="cd-kpi-icon"><i class="fa fa-clock-o"/></span>
                        <span class="cd-kpi-body">
                            <span class="cd-kpi-label">Timesheets</span>
                            <span class="cd-kpi-value"><t t-esc="this.state.login_employee['emp_timesheets']"/></span>
                        </span>
                    </button>
                </div>
                <div class="col-12 col-md-6 col-xl">
                    <button type="button" class="cd-kpi cd-kpi-contract" t-on-click="hr_contract">
                        <span class="cd-kpi-icon"><i class="fa fa-book"/></span>
                        <span class="cd-kpi-body">
                            <span class="cd-kpi-label">Contracts</span>
                            <span class="cd-kpi-value"><t t-esc="this.state.login_employee['contracts_count']"/></span>
                        </span>
                    </button>
                </div>
                <div class="col-12 col-md-6 col-xl">
                    <button type="button" class="cd-kpi cd-kpi-factor" t-on-click="employee_broad_factor">
                        <span class="cd-kpi-icon"><i class="fa fa-bar-chart"/></span>
                        <span class="cd-kpi-body">
                            <span class="cd-kpi-label">Broad Factor</span>
                            <span class="cd-kpi-value"><t t-esc="this.state.login_employee['broad_factor']"/></span>
                        </span>
                    </button>
                </div>
                <div class="col-12 col-md-6 col-xl">
                    <button type="button"
                            class="cd-kpi cd-kpi-attendance"
                            t-ref="log_in_out"
                            t-att-class="this.isAttendanceActionInProgress ? 'attendance-action--disabled' : ''"
                            t-on-click="attendance_sign_in_out">
                        <span class="cd-kpi-icon">
                            <i t-if="this.state.login_employee['attendance_state'] =='checked_out'" class="fa fa-sign-in"/>
                            <i t-if="this.state.login_employee['attendance_state'] =='checked_in'" class="fa fa-sign-out"/>
                        </span>
                        <span class="cd-kpi-body">
                            <span class="cd-kpi-label">Attendance</span>
                            <span class="cd-kpi-value" t-if="this.state.login_employee['attendance_state'] =='checked_out'">Check In</span>
                            <span class="cd-kpi-value" t-if="this.state.login_employee['attendance_state'] =='checked_in'">Check Out</span>
                        </span>
                    </button>
                </div>
            </div>
        </section>

        <section class="cd-block cd-ops-block">
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="cd-card">
                        <div class="cd-card-head">
                            <h3>Attendance</h3>
                            <button type="button" class="cd-add" t-on-click="add_attendance"><i class="fa fa-plus"/></button>
                        </div>
                        <div class="cd-table-wrap">
                            <table class="table table-sm table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Sign In</th>
                                        <th>Sign Out</th>
                                        <th>Worked Hours</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="this.state.login_employee['attendance_lines']" t-as="lines" t-key="lines['id']">
                                        <td t-esc="lines['date']"/>
                                        <td t-esc="lines['sign_in']"/>
                                        <td t-esc="lines['sign_out']"/>
                                        <td t-esc="lines['worked_hours']"/>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="cd-card">
                        <div class="cd-card-head">
                            <h3>Leaves</h3>
                            <button type="button" class="cd-add" t-on-click="add_leave"><i class="fa fa-plus"/></button>
                        </div>
                        <div class="cd-table-wrap">
                            <table class="table table-sm table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>From Date</th>
                                        <th>To Date</th>
                                        <th>Type</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="this.state.login_employee['leave_lines']" t-as="lines" t-key="lines['id']">
                                        <td t-esc="lines['request_date_from']"/>
                                        <td t-esc="lines['request_date_to']"/>
                                        <td t-esc="lines['type']"/>
                                        <td><span class="state_td" t-esc="lines['state']" t-attf-style="background: #{lines['color']};"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="cd-card">
                        <div class="cd-card-head">
                            <h3>Expenses</h3>
                            <button type="button" class="cd-add" t-on-click="add_expense"><i class="fa fa-plus"/></button>
                        </div>
                        <div class="cd-table-wrap">
                            <table class="table table-sm table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Subject</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="this.state.login_employee['expense_lines']" t-as="lines" t-key="lines['id']">
                                        <td t-esc="lines['date']"/>
                                        <td t-esc="lines['name']"/>
                                        <td t-esc="lines['total_amount']"/>
                                        <td><span class="state_td" t-esc="lines['state']" t-attf-style="background: #{lines['color']};"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="cd-card">
                        <div class="cd-card-head">
                            <h3>Projects</h3>
                            <button type="button" class="cd-add" t-on-click="add_project_task"><i class="fa fa-plus"/></button>
                        </div>
                        <div class="cd-table-wrap">
                            <table class="table table-sm table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Project</th>
                                        <th>Task</th>
                                        <th>Due Date</th>
                                        <th>Stage</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="this.state.login_employee['project_task_lines']" t-as="lines" t-key="lines['id']">
                                        <td t-esc="lines['project_name']"/>
                                        <td t-esc="lines['task_name']"/>
                                        <td t-esc="lines['date_deadline']"/>
                                        <td><span class="state_td" t-esc="lines['stage_name']" style="background: #64748b;"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="cd-block cd-feed-block">
            <div class="row g-3">
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="cd-card cd-feed">
                        <div class="cd-card-head"><h3>Upcoming Birthdays</h3></div>
                        <div class="cd-feed-list">
                            <t t-if="this.state.employee_birthday and this.state.employee_birthday.length > 0">
                                <div t-foreach="this.state.employee_birthday" t-as="employee" t-key="employee['id']" class="cd-feed-item">
                                    <img class="cd-feed-avatar" alt="Employee" t-attf-src="/web/image?model=hr.employee&amp;id={{employee['id']}}&amp;field=image_1920"/>
                                    <div>
                                        <p class="cd-feed-title"><t t-esc="employee['name']"/></p>
                                        <p class="cd-feed-sub"><t t-esc="employee['birthday']"/></p>
                                        <p class="cd-feed-sub" t-if="employee['is_birthday']">Happy Birthday</p>
                                        <p class="cd-feed-sub" t-if="employee['days']"><t t-esc="employee['days']"/> days left</p>
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="cd-empty">No upcoming birthdays</div>
                            </t>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="cd-card cd-feed">
                        <div class="cd-card-head"><h3>Upcoming Events</h3></div>
                        <div class="cd-feed-list">
                            <t t-if="this.state.upcoming_events and this.state.upcoming_events.length > 0">
                                <div t-foreach="this.state.upcoming_events" t-as="event" t-key="event['id']" class="cd-feed-item cd-feed-item-no-avatar">
                                    <div>
                                        <p class="cd-feed-title"><t t-esc="event['name']"/></p>
                                        <p class="cd-feed-sub"><t t-esc="event['date_begin']"/> - <t t-esc="event['date_end']"/></p>
                                        <p class="cd-feed-sub">Venue: <t t-esc="event['address_id'] and event['address_id'][1] or 'Online'"/></p>
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="cd-empty">No upcoming events</div>
                            </t>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-xl-4">
                    <div class="cd-card cd-feed">
                        <div class="cd-card-head"><h3>Announcements</h3></div>
                        <div class="cd-feed-list">
                            <t t-if="this.state.announcements and this.state.announcements.length > 0">
                                <div t-foreach="this.state.announcements" t-as="announcement" t-key="announcement['announcement_reason']" class="cd-feed-item cd-feed-item-no-avatar">
                                    <div>
                                        <p class="cd-feed-title"><t t-esc="announcement['announcement_reason']"/></p>
                                        <p class="cd-feed-sub"><t t-esc="announcement['date_start']"/> - <t t-esc="announcement['date_end']"/></p>
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="cd-empty">No announcements</div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="cd-block cd-personal-chart-block">
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="cd-card">
                        <div class="cd-card-head"><h3>My Leave Analysis</h3></div>
                        <div class="cd-chart" t-ref="leave_trend">
                            <canvas id="leaveTrendChart"/>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="cd-card">
                        <div class="cd-card-head"><h3>My Skill Analysis</h3></div>
                        <div class="cd-chart">
                            <canvas id="skillChart"/>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </t>

    <t t-name="ManagerDashboard">
        <section class="cd-block cd-manager-approvals-block">
            <div class="row g-3">
                <div class="col-12 col-xl-4">
                    <div class="cd-card">
                        <div class="cd-card-head"><h3>Approvals</h3></div>
                        <div class="cd-stat-grid">
                            <button type="button" class="cd-stat cd-stat-a" t-on-click="leaves_to_approve">
                                <span>Leave Requests</span>
                                <strong><t t-esc="this.state.login_employee.leaves_to_approve"/></strong>
                            </button>
                            <button type="button" class="cd-stat cd-stat-b" t-on-click="leaves_request_today">
                                <span>Today</span>
                                <strong><t t-esc="this.state.login_employee.leaves_today"/></strong>
                            </button>
                            <button type="button" class="cd-stat cd-stat-c" t-on-click="leaves_request_month">
                                <span>This Month</span>
                                <strong><t t-esc="this.state.login_employee.leaves_this_month"/></strong>
                            </button>
                            <button type="button" class="cd-stat cd-stat-d" t-on-click="leave_allocations_to_approve">
                                <span>Allocation Requests</span>
                                <strong><t t-esc="this.state.login_employee.leaves_alloc_req"/></strong>
                            </button>
                            <button type="button" class="cd-stat cd-stat-e" t-on-click="job_applications_to_approve">
                                <span>Job Applications</span>
                                <strong><t t-esc="this.state.login_employee.job_applications"/></strong>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-xl-8">
                    <div class="cd-card">
                        <div class="cd-card-head"><h3>Departments</h3></div>
                        <div class="cd-chart" t-ref="emp_graph">
                            <canvas id="employeePieChart"/>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="cd-block cd-manager-leave-block">
            <div class="cd-card">
                <div class="cd-card-head"><h3>Monthly Leave Analysis</h3></div>
                <div class="cd-chart-row" t-ref="leave_graph">
                    <div class="cd-chart"><canvas id="leave_barChart"/></div>
                    <div class="cd-chart"><canvas id="leave_doughnutChart"/></div>
                </div>
            </div>
        </section>

        <section class="cd-block cd-manager-trend-block">
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="cd-card">
                        <div class="cd-card-head"><h3>Monthly Join/Resign Analysis</h3></div>
                        <div class="cd-chart" t-ref="join_resign_trend">
                            <canvas id="lineChart"/>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="cd-card">
                        <div class="cd-card-head"><h3>Attrition Rate</h3></div>
                        <div class="cd-chart" t-ref="attrition_rate">
                            <canvas id="attritionRateChart"/>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </t>

    <t t-name="EmployeeWarning">
        <div class="alert alert-warning">Employee profile is not linked to this user. Please contact administrator.</div>
    </t>
</templates>
