<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_bonus_request_list" model="ir.ui.view">
        <field name="name">bonus.request.list</field>
        <field name="model">bonus.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
<!--                <field name="date"/>-->
                <field name="bonus"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_bonus_request_form" model="ir.ui.view">
        <field name="name">bonus.request.form</field>
        <field name="model">bonus.request</field>
        <field name="arch" type="xml">
            <form string="Bonus Request">
                <header>
                    <button name="action_submit_to_manager" string="Submit"
                            invisible="state not in ('draft')"
                            type="object" class="oe_highlight"/>
                    <button name="approve_request" string="Approve"
                            invisible="state not in ('submit')"
                            type="object" class="oe_highlight"
                            groups="hr.group_hr_manager,hr.group_hr_user"/>
                    <button name="approve_request_acc_dept" string="Approve"
                            type="object"
                            invisible="state not in ('waiting_approval')"
                            class="oe_highlight"
                            groups="account.group_account_manager,account.group_account_user"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state not in ('draft','submit')"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state not in ('waiting_approval')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submit,waiting_approval,approve,cancel,reject"/>
                </header>

                <sheet>
                    <div class="oe_title oe_left">
                        <h2>
                            <field name="name" class="oe_inline" readonly="1"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"
                                   readonly="state in ('approve','cancel','reject')"/>
                            <field name="department_id"
                                   readonly="state in ('approve','cancel','reject')"/>
                            <field name="start_date"
                                   readonly="state in ('approve','cancel','reject')"/>
                            <field name="end_date"
                                   readonly="state in ('approve','cancel','reject')"/>
                        </group>
                        <group>
                            <field name="total_net_salary"
                                   readonly="state in ['approve','cancel','reject']"/>
                            <field name="bonus"
                                   readonly="state in ['approve','cancel','reject']"/>
                            <field name="currency_id"
                                   readonly="state in ['approve','cancel','reject']"
                                   groups="base.group_multi_currency"/>
                            <field name="company_id"
                                   readonly="state in ['approve','cancel','reject']"
                                   groups="base.group_multi_currency"/>
                            <field name="credit_id"
                                   invisible="state in ('draft','submit')"
                                   readonly="state in ('approve','cancel','reject')"
                                   groups="account.group_account_manager"/>
                            <field name="debit_id"
                                   invisible="state in ('draft','submit')"
                                   readonly="state in ('approve','cancel','reject')"
                                   groups="account.group_account_manager"/>
                            <field name="journal_id"
                                   invisible="state in ('draft','submit')"
                                   readonly="state in ('approve','cancel','reject')"
                                   groups="account.group_account_manager"/>
                            <field name="employee_contract_id"
                                   readonly="state in ['approve','cancel','reject']"
                                   invisible="state in ('draft','approve')"
                                   groups="hr.group_hr_manager,hr.group_hr_user"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_bonus_request" model="ir.actions.act_window">
        <field name="name">Bonus Requests</field>
        <field name="res_model">bonus.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_bonus_request"
        name="Bonus"
        parent="ohrms_loan.hr_loan_menu_root"
        action="action_bonus_request"
        sequence="25"/>

</odoo>