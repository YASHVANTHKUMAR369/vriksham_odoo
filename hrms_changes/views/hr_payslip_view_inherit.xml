<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="hr_payslip_view_form_inherit" model="ir.ui.view">
        <field name="name">hr.payslip.kanban.contract.info</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll_community.hr_payslip_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='action_compute_sheet']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='date_to']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>

            <xpath expr="//field[@name='credit_note']" position="after">
<!--                <field name="loan_ids" widget="many2many_tags"/>-->
                <field name="gross_salary"/>
                <field name="net_salary"/>
            </xpath>
            <xpath expr="//field[@name='contract_id']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//field[@name='struct_id']" position="attributes">
                <attribute name="readonly">0</attribute>
                <attribute name="force_save">1</attribute>
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//notebook" position="replace">
                <notebook>
                    <page string="Worked Days &amp; Inputs">
                    <separator string="Other Inputs"/>
                                <field name="input_line_ids" colspan="4" nolabel="1" readonly="state != 'draft'" context="{'default_contract_id': contract_id}">
                                    <list string="Input Data" editable="bottom">
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="amount"/>
                                        <field name="contract_id"/>
                                        <field name="sequence" coloum_invisible="True"/>
                                    </list>
                                    <form string="Payslip Line">
                                        <group col="4">
                                            <field name="name"/>
                                            <field name="code"/>
                                            <field name="sequence"/>
                                            <field name="amount"/>
                                            <field name="contract_id"/>
                                        </group>
                                    </form>
                                </field>
                        <separator string="Worked Days"/>
                        <group>
                            <field name="days_calculation" readonly="1" force_save="1"/>
                        </group>
                    </page>
                    <page string="Salary Calculation">
                        <group>
                            <field name="payslip_calculation_html" readonly="1"/>
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>