<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_view_form_hr_signature_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.hr.signature</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='hr']/block[@name='employees_setting_container']" position="inside">
                <setting id="hr_signature_setting" string="HR Signature" help="Used in offer letter signatures." groups="base.group_system">
                    <div class="content-group mt16">
                        <div class="row g-3 align-items-start">
                            <div class="col-12 col-lg-6">
                                <label for="hr_name" class="o_light_label"/>
                                <field name="hr_name" placeholder="Enter HR name" class="w-100"/>
                            </div>
                        </div>
                        </div>
                        <div class="content-group mt16">
                        <div class="row g-3 align-items-start">
                            <div class="col-12 col-lg-6">
                                <label for="hr_signature" class="o_light_label"/>
                                <field name="hr_signature" widget="image" options="{'size': [220, 80]}"/>
                            </div>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
