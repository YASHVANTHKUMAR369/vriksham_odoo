<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="hr_kanban_view_employees_inherit" model="ir.ui.view">
        <field name="name">hr.employee.kanban.contract.info</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.hr_kanban_view_employees"/>
        <field name="arch" type="xml">
            <xpath expr="//t[@t-name='card']" position="inside">
                <field name="first_joining_date" invisible="1"/>
                <field name="last_working_date" invisible="1"/>
            </xpath>

            <xpath expr="//div[field[@name='contract_date_end']]" position="after">
                <div t-if="record.first_joining_date.raw_value" groups="hr.group_hr_manager"
                     t-att-class="{'text-danger': record.last_working_date.raw_value &lt; luxon.DateTime.now().toISO()}">

                    <i class="fa fa-fw me-2 fa-user text-primary" title="Contract"/>
                    <span>Overall :</span>
                    <field class="px-1" name="first_joining_date"/>
                    <span t-if="record.last_working_date.raw_value">-</span>
                    <field class="px-1" t-if="record.last_working_date.raw_value" name="last_working_date"/>
                </div>
            </xpath>
        </field>
    </record>


    <record id="view_employee_form_inherit" model="ir.ui.view">
        <field name="name">employee.document.view</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='department_id']" position="before">
                <field name="struct_id"/>
            </xpath>
            <xpath expr="//field[@name='employee_type']" position="before">
                <field name="tds_amount"/>
            </xpath>
            <xpath expr="//label[@for='wage']" position="attributes">
                <attribute name="string">CTC</attribute>
            </xpath>

            <!-- Change Field Display Name -->
            <xpath expr="//field[@name='wage']" position="attributes">
                <attribute name="string">CTC</attribute>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="Salary Calculation">
                    <header>
                        <button name="action_print_offer_full_report"
                                type="object"
                                string="Offer Letter ( FULL )"
                                class="btn-primary" invisible="is_first_version != True"/>
                        <button name="action_print_offer_basic_report"
                                type="object"
                                string="Offer Letter ( BASIC )"
                                class="btn-primary" invisible="is_first_version != True"/>
                        <button name="action_print_experience_report"
                                type="object"
                                string="Experience Letter"
                                class="btn-primary" invisible="is_last_version == False or active==True"/>
                        <button name="action_print_hike_report"
                                type="object"
                                string="Hike Letter"
                                class="btn-primary" invisible="is_first_version == True"/>
                        <button name="action_print_relieving_report"
                                type="object"
                                string="Relieving Letter"
                                class="btn-primary" invisible="is_last_version == False or active==True"/>
                    </header>
                    <group>
                        <group>

                            <field name="salary_calculation_id" required="1"/>
                            <field name="hire_date" required="1"/>
                            <field name="hike_date" readonly="is_first_version"/>
                        </group>
                        <group>
                            <field name="departure_reason_id" invisible="active"/>
                            <field name="is_first_version" invisible="1"/>
                            <field name="is_last_version" invisible="1"/>
                            <field name="departure_date" string="Relieving Date" invisible="active"/>
                        </group>
                    </group>
                    <field name="salary_calculation_html"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>