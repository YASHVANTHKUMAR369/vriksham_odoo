<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_users_form_inherit_signature" model="ir.ui.view">
            <field name="name">res.users.form.signature</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='page_security']" position="after">
                    <page name="page_signature" string="Signature">
                        <group>
                            <field name="sign_signature" widget="image"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
